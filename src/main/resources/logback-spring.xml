<configuration scan="true">

    <!-- Definir variable con fallback para Logstash -->
    <property name="LOGSTASH_HOST" value="${ELASTIC_HOST:-localhost:5000}"/>

    <!-- Importar la propiedad de Spring Boot -->
    <springProperty scope="context" name="springAppName" source="spring.application.name"/>

    <!-- Consola -->
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} %-5level [%thread] %logger{36} - [%X{traceId:-}] %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- Logstash TCP -->
    <appender name="LOGSTASH" class="net.logstash.logback.appender.LogstashTcpSocketAppender">
        <destination>${LOGSTASH_HOST}</destination>
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <!-- Se usa la propiedad springAppName en vez de spring.application.name -->
            <customFields>{"service":"${springAppName}"}</customFields>
        </encoder>
    </appender>

    <!-- Root logger -->
    <root level="INFO">
        <appender-ref ref="STDOUT"/>
        <appender-ref ref="LOGSTASH"/>
    </root>

    <!-- Logger específico del microservicio -->
    <logger name="pe.nom.charlygastelo.app.customerservice" level="DEBUG" additivity="false">
        <appender-ref ref="STDOUT"/>
        <appender-ref ref="LOGSTASH"/>
    </logger>

</configuration>
